{
  "apps": [
    {
      "appId": "com.dotharness.dotcraft-unity",
      "toolNamespace": "unity",
      "displayName": "Unity Editor",
      "developerName": "DotHarness",
      "description": "Connect a running Unity Editor so selected DotCraft threads can run C# automation through unity_execute_csharp.",
      "category": "Engineering",
      "icon": "./assets/dotcraft-unity.svg",
      "releasePage": "https://github.com/DotHarness/dotcraft-unity",
      "nativeApplication": {
        "displayName": "Unity Editor",
        "installUrl": "https://unity.com/download"
      },
      "connection": {
        "handoffModes": [
          {
            "mode": "url",
            "uriTemplate": "http://127.0.0.1:39777/dotcraft/{operation}?app={appId}&request={requestId}&token={requestToken}&endpoint={endpoint}&scopes={scopes}"
          }
        ]
      },
      "scopes": [
        {
          "id": "unity.execute",
          "displayName": "Execute Unity C#",
          "description": "Run C# automation through unity_execute_csharp in the connected Unity Editor.",
          "risk": "mutate",
          "defaultSelected": true
        }
      ],
      "dynamicToolCatalog": {
        "enabled": true,
        "description": "The running Unity Editor publishes unity_execute_csharp for this thread."
      },
      "toolCatalog": []
    }
  ]
}
